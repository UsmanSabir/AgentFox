{
    "LLM": {
        "Provider": "Ollama",
        "Model": "phi4-mini",
        "BaseUrl": "http://localhost:11434",
        "TimeoutSeconds": 3600,
        "Headers": {
            "a": "b"
        }
    },
    "Models": {
        "CheapModel": {
            "Provider": "Ollama",
            "Model": "phi4-mini",
            "BaseUrl": "http://localhost:11434",
            "TimeoutSeconds": 3600
        },
        "FastModel": {
            "Provider": "Ollama",
            "Model": "llama3.2",
            "BaseUrl": "http://localhost:11434",
            "TimeoutSeconds": 1800
        },
        "ReasoningModel": {
            "Provider": "Ollama",
            "Model": "deepseek-r1",
            "BaseUrl": "http://localhost:11434",
            "TimeoutSeconds": 7200
        }
    },

    "Memory": {
        "LongTermStorage": "Sqlite", //Sqlite or Markdown
        "MarkdownPath": "LongTermMemory.md",
        "SqlitePath": "LongTermMemory.db",
        "Embedding": {
            "Provider": "OpenAI", //OpenAI, Ollama, "None" (or omitted), it falls back to the existing BM25 search
            "Model": "text-embedding-all-minilm-l6-v2", // "text-embedding-3-small", //"nomic-embed-text", 
            "BaseUrl": "http://127.0.0.1:1234/v1", //"http://localhost:11434"
            "ApiKey": "something"
        }
    },
    "Compaction": {
        "Enabled": false,
        "TriggerThreshold": 4000,
        "ToolResultThreshold": 4000,
        "SummarizationThreshold": 8000,
        "TruncationThreshold": 12000,
        "SummarizationModelKey": "CheapModel"
    },
    "Composio": {
        "ApiKey": "your-composio-api-key-here",
        "EnableDetailedLogging": false,
        "CacheTimeoutSeconds": 3600
    },
    "MCP": {
        "Servers": [
            {
                "Name": "example-mcp-server",
                "Url": "http://localhost:3000",
                "TimeoutSeconds": 30,
                "Headers1": {
                    "Authorization": "Bearer YOUR_TOKEN_HERE"
                }
            }
        ]
    },
    "Workspaces": [
        "e:\\code\\CSharpClaw"
    ]
}
