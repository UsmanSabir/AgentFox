{
  "UI": {
    "RenderReasoning": true
  },
  "Services": {
    "Enabled": true,
    "ServiceName": "AgentFox",
    "DisplayName": "AgentFox - Multi-Agent AI Framework",
    "Description": "Multi-agent AI framework running in web mode with agent processing, memory, scheduling, and MCP support.",
    "Port": 8080,
    "RunAsAdmin": true,
    "AutoStart": true,
    "LogPath": "{workspace}/logs/service.log",
    "HeartbeatIntervalSeconds": 5,
    "EnvironmentVariables": {}
  },
  "Modules": "cli,web",
  "Logging": {
    "UseFileLogger": true,
    "FilePath": "logs/agentfox.log",
    "MinLevel": "Warning",
    "RetentionDays": 3
  },
  "LLM": {
    "Provider": "Ollama",
    "Model": "phi4-mini",
    "BaseUrl": "http://localhost:11434",
    "TimeoutSeconds": 3600,
    "Headers": {
      "a": "b"
    }
  },
  "Models": {
    "LM": {
      "Provider": "OpenAi",
      "ApiKey": "aaa",
      "Model": "qwen0.8b",
      "BaseUrl": "http://127.0.0.1:1234/v1",
      "TimeoutSeconds": 3600
    },
    "CheapModel": {
      "Provider": "Ollama",
      "Model": "phi4-mini",
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 3600
    },
    "FastModel": {
      "Provider": "Ollama",
      "Model": "llama3.2",
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 1800
    },
    "ReasoningModel": {
      "Provider": "Ollama",
      "Model": "deepseek-r1",
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 7200
    },
    // "SubAgent": {                  // Optional: dedicated model for background sub-agents.
    //     "Provider": "Ollama",      // If omitted, sub-agents use the primary LLM (LLM section).
    //     "Model": "llama3.2",
    //     "BaseUrl": "http://localhost:11434",
    //     "TimeoutSeconds": 1800
    // },
    "Embedding": {
      "Provider": "Local", // "Local", "OpenAI", "Ollama", "None" (or omitted), it falls back to the existing BM25 search
      "Model": "text-embedding-all-minilm-l6-v2", // "text-embedding-3-small", //"nomic-embed-text", 
      "BaseUrl": "http://127.0.0.1:1234/v1", //"http://localhost:11434"
      "ApiKey": "something"
    }
  },

  "Memory": {
    "LongTermStorage": "Sqlite", //Sqlite or Markdown
    "MarkdownPath": "LongTermMemory.md",
    "SqlitePath": "LongTermMemory.db",
    "ModelRef": "Embedding"
  },
  "Compaction": {
    "Enabled": false,
    "TriggerThreshold": 400,
    "ToolResultThreshold": 400,
    "SummarizationThreshold": 800,
    "TruncationThreshold": 1200,
    "SummarizationModelKey": "LM"
  },
  "Composio": {
    "ApiKey": "your-composio-api-key-here",
    "EnableDetailedLogging": false,
    "CacheTimeoutSeconds": 3600
  },
  "MCP": {
    "Servers": [
      {
        "Name": "example-http-server",
        "Transport": {
          "Type": "Http",
          "Url": "http://localhost:3000/mcp",
          "Headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          }
        }
      },
      {
        "Name": "example-sse-server",
        "Transport": {
          "Type": "Sse",
          "Url": "http://localhost:3001/sse",
          "MaxReconnectionAttempts": 5
        }
      },
      {
        "Name": "example-stdio-server",
        "Transport": {
          "Type": "Stdio",
          "Command": "npx",
          "Arguments": [ "-y", "@modelcontextprotocol/server-filesystem", "C:\\workspace" ],
          "WorkingDirectory": "C:\\workspace",
          "Env": {
            "NODE_ENV": "production"
          },
          "ShutdownTimeoutSeconds": 5
        }
      }
    ]
  },
  "Sessions": {
    "IdleTimeoutMinutes": 30,
    "ArchiveRetentionDays": 30,
    "SessionDirectory": "sessions",
    "ArchiveDirectory": "archive/sessions",
    "BackgroundCheckIntervalSeconds": 60
  },
  "RestrictToWorkspace": true,
  "Workspaces": [
    "e:\\code\\CSharpClaw"
  ],
  "Channels": [
    {
      "Type": "Telegram",
      "Enabled": false,
      "BotToken": "your-telegram-bot-token-here",
      "PollingTimeoutSeconds": 30,
      "ChatId": "your-telegram-chat-id-here"
    },
    {
      "Type": "Discord",
      "Enabled": false,
      "BotToken": "your-discord-bot-token-here",
      "GuildId": "server-id",
      "DefaultChannelId": "channel-id-here"
    }
    // Add more channels here — same Type can appear multiple times:
    // { "Type": "Telegram", "Enabled": true, "BotToken": "second-bot-token", ... },
    // { "Type": "Discord",  "Enabled": true, "BotToken": "...", "GuildId": "...", "DefaultChannelId": "..." }
  ],

  // Tool groups — set any to false to skip registration.
  // Useful profiles:
  //   Docker / sandboxed : Shell=false, FileSystem=false, SystemInfo=false
  //   Read-only agent    : Shell=false, Disabled=["write_file","delete","make_directory"]
  "Tools": {
    "Shell":      true,
    "FileSystem": true,
    "Web":        true,
    "Utilities":  true,
    "SystemInfo": true,
    "Memory":     true,
    "SubAgent":   true,
    "Scheduling": true,
    "Channels":   true,
    "Mcp":        true,
    "Disabled":   []
  },

  "Plugins": {
    "BraveSearch": {
      "ApiKey": "your-brave-search-api-key-here"
    },
    "Tavily": {
      "ApiKey": "",
      "SearchDepth": "advanced", // "basic" or "advanced"
      "MaxResults": 5,
      "IncludeAnswer": true
    },
    "PageAgent": {
      "UseSystemProfile": true,
      "UseProfileCopy": false,
      "KillConflictingBrowser": true,
      "UserDataDir": "C:\\Users\\YourName\\AppData\\Local\\Google\\Chrome\\User Data"
    }
  }

}
